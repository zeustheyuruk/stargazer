<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Stargazer Premium PWA</title>
    <!-- Apple PWA Meta Etiketleri -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Stargazer">
    <style>
        /* ==========================================================================
           1. TEMA VE DEĞİŞKEN SİSTEMİ (:root)
           ========================================================================== */
        :root, [data-theme="layover-night"] {
            --bg-primary: #0a0e17;
            --bg-secondary: #121824;
            --bg-surface: rgba(26, 34, 50, 0.7);
            --accent: #3b82f6;
            --accent-hover: #2563eb;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border-color: rgba(255, 255, 255, 0.08);
            --glass-blur: blur(16px);
            --widget-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }
        [data-theme="crew-gold"] {
            --bg-primary: #110f0c;
            --bg-secondary: #1a1712;
            --bg-surface: rgba(34, 30, 24, 0.7);
            --accent: #d4af37;
            --accent-hover: #aa8c2c;
            --text-primary: #fdfbf7;
            --text-secondary: #a69f92;
            --border-color: rgba(212, 175, 55, 0.15);
        }
        [data-theme="apron-dusk"] {
            --bg-primary: #161214;
            --bg-secondary: #221a1e;
            --bg-surface: rgba(43, 33, 38, 0.7);
            --accent: #f43f5e;
            --accent-hover: #e11d48;
            --text-primary: #fff1f2;
            --text-secondary: #cca7aa;
            --border-color: rgba(244, 63, 94, 0.15);
        }
        [data-theme="sky-lounge"] {
            --bg-primary: #0b131a;
            --bg-secondary: #132230;
            --bg-surface: rgba(27, 47, 66, 0.7);
            --accent: #06b6d4;
            --accent-hover: #0891b2;
            --text-primary: #ecfeff;
            --text-secondary: #94a3b8;
            --border-color: rgba(6, 182, 212, 0.15);
        }

        /* ==========================================================================
           2. SIFIRLAMA VE GLOBAL SILLER (Mobil-First & Anti-Zoom)
           ========================================================================== */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
            padding-bottom: 90px;
            font-size: 15px;
            line-height: 1.5;
        }
        input, select, textarea {
            font-size: 16px !important; /* iOS Auto-zoom engelleyici kritik kural */
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            border-radius: 10px;
            padding: 12px;
            width: 100%;
            outline: none;
            transition: border-color 0.2s;
        }
        input:focus, select:focus {
            border-color: var(--accent);
        }
        button {
            cursor: pointer;
            border: none;
            border-radius: 10px;
            padding: 12px 20px;
            font-weight: 600;
            transition: background 0.2s, transform 0.1s;
        }
        button:active {
            transform: scale(0.98);
        }
        .btn-primary {
            background: var(--accent);
            color: #fff;
        }
        .btn-primary:hover { background: var(--accent-hover); }
        .btn-secondary {
            background: var(--bg-secondary);
            color: var(--text-primary);
            border: 1px solid var(--border-color);
        }

        /* ==========================================================================
           3. LAYOUT & GRID (Premium Apple Widget Hissiyatı)
           ========================================================================== */
        .app-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px 16px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-top: env(safe-area-inset-top);
        }
        .header h1 {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .widget-card {
            background: var(--bg-surface);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 18px;
            margin-bottom: 16px;
            box-shadow: var(--widget-shadow);
        }
        .widget-title {
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
            margin-bottom: 12px;
        }

        /* ==========================================================================
           4. SEKME YÖNETİMİ (Tab Navigation)
           ========================================================================== */
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(18, 24, 36, 0.85);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-around;
            padding: 10px 0 calc(10px + env(safe-area-inset-bottom)) 0;
            z-index: 900;
        }
        .nav-item {
            background: none;
            border: none;
            color: var(--text-secondary);
            display: flex;
            flex-direction: column;
            align-items: center;
            font-size: 11px;
            font-weight: 500;
            padding: 4px 12px;
            width: 14%;
        }
        .nav-item.active {
            color: var(--accent);
        }
        .nav-icon {
            font-size: 20px;
            margin-bottom: 4px;
        }

        /* ==========================================================================
           5. MODÜL ÖZEL CSS (Flights, Explore, Shop, Checklist)
           ========================================================================== */
        /* Home */
        .theme-selector {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        /* Flights */
        .flight-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 12px;
        }
        .flight-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 14px;
            margin-bottom: 12px;
            position: relative;
        }
        .flight-actions {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            margin-top: 10px;
        }
        .validation-warning {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: none;
        }
        /* Explore Modları (Taşmayı Önleyen Esnek Düzen) */
        .explore-modes {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-bottom: 16px;
        }
        .explore-modes button {
            padding: 14px 10px;
            font-size: 13px;
            text-align: center;
            white-space: normal; /* İki satıra izin ver */
            word-wrap: break-word;
        }
        .explore-modes button.signature-mode {
            grid-column: span 2; /* Signature tam satır kaplasın, kesilmesin */
        }
        .explore-modes button.active-mode {
            border: 2px solid var(--accent);
            background: var(--bg-secondary);
        }
        /* Shop */
        .shop-options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .source-tag {
            display: inline-block;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-color);
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 11px;
            color: var(--text-secondary);
            margin-top: 6px;
        }
        /* Checklist */
        .checklist-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--border-color);
        }
        .checklist-item:last-child { border-bottom: none; }
        .checklist-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .checklist-item input[type="checkbox"] {
            width: auto !important;
        }
        .undeletable-badge {
            font-size: 10px;
            background: rgba(255,255,255,0.1);
            padding: 2px 6px;
            border-radius: 4px;
            color: var(--text-secondary);
        }

